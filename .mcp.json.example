{
  "mcpServers": {
    "tavily": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic-ai/mcp-remote@latest",
        "https://mcp.tavily.com/mcp/?tavilyApiKey=API_KEY"
      ]
    },
    "notion": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic-ai/mcp-remote@latest",
        "https://mcp.notion.so/mcp/?ntn_token=API_KEY"
      ]
    }
  }
}
